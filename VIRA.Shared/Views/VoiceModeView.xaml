<Page
    x:Class="VIRA.Shared.Views.VoiceModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VIRA.Shared.Views"
    Background="{StaticResource BackgroundBrush}">

    <Grid>
        <!-- Ambient background effects -->
        <Rectangle Fill="{StaticResource AmbientGlowBrush}" 
                   VerticalAlignment="Top" 
                   Height="300" 
                   Opacity="0.3"/>
        
        <Grid Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="VOICE MODE" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    
                    <!-- Live indicator -->
                    <Border Background="#ef4444" 
                            CornerRadius="12" 
                            Padding="8,4">
                        <TextBlock Text="Live" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>
                </StackPanel>
                
                <!-- Close button -->
                <Button x:Name="CloseButton"
                        Content="✕"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="24"
                        Width="44"
                        Height="44"
                        Click="OnCloseClick"/>
            </Grid>
            
            <!-- Transcript display area -->
            <ScrollViewer Grid.Row="1" 
                          VerticalAlignment="Center"
                          Margin="0,40,0,40">
                <TextBlock x:Name="TranscriptText"
                           Text="{x:Bind Transcript, Mode=OneWay}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           FontSize="20"
                           LineHeight="32"
                           Foreground="#F1F5F9"
                           MaxWidth="600"/>
            </ScrollViewer>
            
            <!-- Waveform visualizer in center -->
            <Grid Grid.Row="2" 
                  VerticalAlignment="Center"
                  Margin="0,0,0,40">
                <StackPanel Spacing="32" HorizontalAlignment="Center">
                    <!-- Waveform -->
                    <local:WaveformVisualizer x:Name="Waveform"
                                              Height="60"
                                              Width="300"/>
                    
                    <!-- Large circular voice button -->
                    <Grid HorizontalAlignment="Center">
                        <Ellipse x:Name="VoiceButtonGlow"
                                 Width="100"
                                 Height="100"
                                 Fill="{StaticResource PurpleGradientBrush}"
                                 Opacity="0.3"/>
                        
                        <Button x:Name="VoiceButton"
                                Width="80"
                                Height="80"
                                CornerRadius="40"
                                Background="{StaticResource PurpleGradientBrush}"
                                Click="OnVoiceButtonClick">
                            <TextBlock Text="🎤" 
                                       FontSize="32"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                    
                    <!-- Status text -->
                    <TextBlock x:Name="StatusText"
                               Text="{x:Bind StatusMessage, Mode=OneWay}"
                               TextAlignment="Center"
                               FontSize="14"
                               Foreground="#94a3b8"/>
                </StackPanel>
            </Grid>
            
            <!-- Voice controls at bottom -->
            <Grid Grid.Row="3" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            Spacing="16">
                    <!-- Message button -->
                    <Button x:Name="MessageButton"
                            Width="56"
                            Height="56"
                            CornerRadius="28"
                            Background="#FFFFFF14"
                            Click="OnMessageClick">
                        <TextBlock Text="💬" FontSize="24"/>
                    </Button>
                    
                    <!-- Voice button (duplicate for controls) -->
                    <Button x:Name="VoiceControlButton"
                            Width="56"
                            Height="56"
                            CornerRadius="28"
                            Background="#FFFFFF14"
                            Click="OnVoiceButtonClick">
                        <TextBlock Text="🎤" FontSize="24"/>
                    </Button>
                    
                    <!-- Volume button -->
                    <Button x:Name="VolumeButton"
                            Width="56"
                            Height="56"
                            CornerRadius="28"
                            Background="#FFFFFF14"
                            Click="OnVolumeClick">
                        <TextBlock Text="🔊" FontSize="24"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
