<UserControl x:Class="VIRA.Shared.Views.ScheduleCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:VIRA.Shared.Models"
             xmlns:converters="using:VIRA.Shared.Converters">
    
    <UserControl.Resources>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
    </UserControl.Resources>
    
    <Border Background="{StaticResource SemiTransparentWhite5Brush}" 
            BorderBrush="{StaticResource SemiTransparentWhite14Brush}" 
            BorderThickness="1"
            CornerRadius="{StaticResource MediumRadius}"
            Padding="{StaticResource SpacingMedium}">
        
        <StackPanel Spacing="{StaticResource SpacingSmall}">
            <!-- Header -->
            <TextBlock Text="📅 Today's Schedule" 
                       FontSize="{StaticResource FontSizeLarge}" 
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontWeight="SemiBold"/>
            
            <!-- Schedule Items List -->
            <ItemsRepeater ItemsSource="{x:Bind ScheduleItems, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:ScheduleItem">
                        <Border Background="{StaticResource SemiTransparentWhite8Brush}" 
                                CornerRadius="{StaticResource SmallRadius}" 
                                Padding="12"
                                Margin="0,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Colored Indicator -->
                                <Border Grid.Column="0"
                                        Width="4"
                                        CornerRadius="2"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Stretch">
                                    <Border.Background>
                                        <SolidColorBrush Color="{x:Bind Color, Converter={StaticResource StringToColorConverter}}"/>
                                    </Border.Background>
                                </Border>
                                
                                <!-- Schedule Details -->
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <!-- Time -->
                                    <TextBlock Text="{x:Bind Time}" 
                                               FontSize="{StaticResource FontSizeSmall}" 
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               FontWeight="SemiBold"/>
                                    
                                    <!-- Title -->
                                    <TextBlock Text="{x:Bind Title}" 
                                               FontSize="{StaticResource FontSizeNormal}" 
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap"
                                               FontWeight="Medium"/>
                                    
                                    <!-- Location -->
                                    <TextBlock Text="{x:Bind Location}" 
                                               FontSize="{StaticResource FontSizeSmall}" 
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </Border>
</UserControl>
