<Page
    x:Class="VIRA.Shared.Views.MainChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:VIRA.Shared.Views"
    mc:Ignorable="d">

    <Grid>
        <!-- Background with gradient -->
        <Grid.Background>
            <SolidColorBrush Color="{StaticResource BackgroundColor}"/>
        </Grid.Background>
        
        <!-- Ambient glow effect -->
        <Rectangle VerticalAlignment="Top" Height="400" Opacity="0.3">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="{StaticResource AmbientGlowPurpleColor}" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Main content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Messages -->
                <RowDefinition Height="Auto"/> <!-- Quick Actions -->
                <RowDefinition Height="Auto"/> <!-- Input Area -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Padding="20,16" Background="#14FFFFFF">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Menu Button -->
                <Button x:Name="MenuButton"
                        Grid.Column="0"
                        Width="40" Height="40"
                        Background="Transparent"
                        Click="OnMenuButtonClick"
                        AutomationProperties.Name="Open menu">
                    <FontIcon Glyph="&#xE700;" FontSize="20" Foreground="White"/>
                </Button>

                <!-- Greeting and Status -->
                <StackPanel Grid.Column="1" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock x:Name="GreetingText"
                               Text="{x:Bind Greeting, Mode=OneWay}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Spacing="8">
                        <Ellipse Width="8" Height="8" 
                                 Fill="{StaticResource SuccessGreenBrush}"/>
                        <TextBlock Text="Vira AI"
                                   FontSize="13"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Settings Button -->
                <Button x:Name="SettingsButton"
                        Grid.Column="2"
                        Width="40" Height="40"
                        Background="Transparent"
                        Click="OnSettingsButtonClick"
                        AutomationProperties.Name="Open settings">
                    <FontIcon Glyph="&#xE713;" FontSize="20" Foreground="White"/>
                </Button>
            </Grid>

            <!-- Message List -->
            <ScrollViewer Grid.Row="1" 
                          x:Name="MessageScrollViewer"
                          Padding="20,16">
                <ItemsRepeater x:Name="MessageList"
                               ItemsSource="{x:Bind Messages, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <local:MessageBubble MessageContent="{Binding}"/>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Quick Action Bar -->
            <ScrollViewer Grid.Row="2" 
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Padding="20,8">
                <ItemsRepeater x:Name="QuickActionBar"
                               ItemsSource="{x:Bind QuickActions, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="12"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button Background="{StaticResource SemiTransparentWhite8Brush}"
                                    BorderBrush="{StaticResource SemiTransparentWhite14Brush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16,10"
                                    Click="OnQuickActionClick"
                                    Tag="{Binding}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Icon}" FontSize="16"/>
                                    <TextBlock Text="{Binding Label}" 
                                               FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Floating Input Area -->
            <Grid Grid.Row="3" Padding="20,16">
                <Border CornerRadius="32"
                        Background="{StaticResource SemiTransparentWhite8Brush}"
                        BorderBrush="{StaticResource SemiTransparentWhite14Brush}"
                        BorderThickness="1"
                        Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- New Chat Button -->
                        <Button Grid.Column="0"
                                Width="40" Height="40"
                                Background="Transparent"
                                CornerRadius="20"
                                AutomationProperties.Name="New chat">
                            <FontIcon Glyph="&#xE710;" FontSize="16" Foreground="White"/>
                        </Button>

                        <!-- Text Input -->
                        <TextBox x:Name="MessageInput"
                                 Grid.Column="1"
                                 PlaceholderText="Message Vira..."
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 VerticalAlignment="Center"
                                 Padding="8,0"
                                 KeyDown="OnMessageInputKeyDown"
                                 AutomationProperties.Name="Message input"/>

                        <!-- Voice Button -->
                        <Button x:Name="VoiceButton"
                                Grid.Column="2"
                                Width="40" Height="40"
                                Background="{StaticResource PurpleGradientBrush}"
                                CornerRadius="20"
                                Margin="4,0"
                                Click="OnVoiceButtonClick"
                                AutomationProperties.Name="Voice input">
                            <FontIcon Glyph="&#xE720;" FontSize="16" Foreground="White"/>
                        </Button>

                        <!-- Send Button -->
                        <Button x:Name="SendButton"
                                Grid.Column="3"
                                Width="40" Height="40"
                                Background="{StaticResource PurpleGradientBrush}"
                                CornerRadius="20"
                                Click="OnSendButtonClick"
                                AutomationProperties.Name="Send message">
                            <FontIcon Glyph="&#xE724;" FontSize="16" Foreground="White"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Bottom handle indicator -->
                <Border Width="40" Height="4"
                        Background="{StaticResource SemiTransparentWhite14Brush}"
                        CornerRadius="2"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,-12"/>
            </Grid>
        </Grid>
        
        <!-- Chat History Sidebar (overlay on top) -->
        <local:ChatHistorySidebar x:Name="ChatSidebar"
                                  ChatSelected="OnChatSelected"
                                  NewChatRequested="OnNewChatRequested"
                                  ClearHistoryRequested="OnClearHistoryRequested"/>
        
        <!-- Loading Indicator -->
        <local:LoadingIndicator x:Name="LoadingIndicator"/>
        
        <!-- Error Snackbar (overlay on top) -->
        <local:ErrorSnackbar x:Name="ErrorNotification"/>
    </Grid>
</Page>
