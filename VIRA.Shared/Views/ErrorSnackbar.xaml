<UserControl
    x:Class="VIRA.Shared.Views.ErrorSnackbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" 
          VerticalAlignment="Top"
          HorizontalAlignment="Center"
          Margin="0,20,0,0"
          Visibility="Collapsed">
        <Border x:Name="SnackbarBorder"
                CornerRadius="12"
                Padding="16,12"
                MinWidth="280"
                MaxWidth="400"
                Background="#1a1f2e"
                BorderThickness="1">
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Icon -->
                <TextBlock x:Name="IconText"
                           Grid.Column="0"
                           Text="❌"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                
                <!-- Message -->
                <TextBlock x:Name="MessageText"
                           Grid.Column="1"
                           Text="Error message"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                
                <!-- Close button -->
                <Button x:Name="CloseButton"
                        Grid.Column="2"
                        Content="✕"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="16"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Margin="8,0,0,0"
                        Click="OnCloseClick"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
