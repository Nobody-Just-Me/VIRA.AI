<Page
    x:Class="VIRA.Shared.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#101622">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Width="36" Height="36"
                    Background="Transparent"
                    CornerRadius="8"
                    Click="OnBackClick">
                <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="#94A3B8"/>
            </Button>

            <TextBlock Grid.Column="1"
                       Text="Pengaturan"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </Grid>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="24">
                
                <!-- API Key Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Gemini API Key"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    
                    <TextBlock Text="Masukkan API Key dari Google AI Studio untuk mengaktifkan Vira"
                               FontSize="13"
                               Foreground="#94A3B8"
                               TextWrapping="Wrap"/>
                    
                    <PasswordBox x:Name="ApiKeyBox"
                                 PlaceholderText="Masukkan API Key..."
                                 Background="#1E293B"
                                 Foreground="White"
                                 BorderBrush="#334155"
                                 CornerRadius="12"
                                 Padding="16,12"
                                 FontSize="14"/>
                    
                    <Button Content="Simpan API Key"
                            Background="#256AF4"
                            Foreground="White"
                            CornerRadius="12"
                            Padding="24,12"
                            HorizontalAlignment="Stretch"
                            Click="OnSaveApiKeyClick"/>
                    
                    <Button Content="Test Koneksi"
                            Background="#1E293B"
                            Foreground="White"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="24,12"
                            HorizontalAlignment="Stretch"
                            Click="OnTestConnectionClick"/>
                </StackPanel>

                <!-- Voice Settings -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Pengaturan Suara"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    
                    <ToggleSwitch x:Name="VoiceOutputToggle"
                                  Header="Aktifkan Output Suara"
                                  IsOn="True"
                                  Foreground="#94A3B8"/>
                    
                    <ToggleSwitch x:Name="AutoListenToggle"
                                  Header="Auto-listen setelah respons"
                                  IsOn="False"
                                  Foreground="#94A3B8"/>
                </StackPanel>

                <!-- About Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Tentang VIRA"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    
                    <Border Background="#1E293B"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="VIRA v1.0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="Virtual Intelligent Responsive Assistant"
                                       FontSize="12"
                                       Foreground="#94A3B8"/>
                            <TextBlock Text="Powered by Google Gemini AI"
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Get API Key Link -->
                <HyperlinkButton Content="Dapatkan API Key dari Google AI Studio →"
                                 NavigateUri="https://aistudio.google.com/app/apikey"
                                 Foreground="#6366F1"
                                 FontSize="13"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
