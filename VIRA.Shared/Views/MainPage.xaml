<Page
    x:Class="VIRA.Shared.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:VIRA.Shared.Models"
    mc:Ignorable="d"
    Background="#101622">

    <Page.Resources>
        <!-- Message Template Selector -->
        <DataTemplate x:Key="UserMessageTemplate" x:DataType="models:ChatMessage">
            <Grid Margin="0,8" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="1"
                        Background="#256AF4"
                        CornerRadius="16,16,2,16"
                        Padding="16,12"
                        MaxWidth="320"
                        HorizontalAlignment="Right">
                    <TextBlock Text="{x:Bind Content}"
                               Foreground="White"
                               TextWrapping="Wrap"
                               FontSize="15"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AssistantMessageTemplate" x:DataType="models:ChatMessage">
            <Grid Margin="0,8" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0"
                        Background="#1E293B"
                        Opacity="0.9"
                        CornerRadius="16,16,16,2"
                        Padding="16,12"
                        MaxWidth="320"
                        HorizontalAlignment="Left">
                    <Border.BackgroundTransition>
                        <BrushTransition Duration="0:0:0.3"/>
                    </Border.BackgroundTransition>
                    
                    <TextBlock Text="{x:Bind Content}"
                               Foreground="#F8FAFC"
                               TextWrapping="Wrap"
                               FontSize="15"/>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <!-- Background Gradient Effects -->
        <Canvas>
            <Ellipse Width="195" Height="442" 
                     Canvas.Left="-39" Canvas.Top="-88"
                     Fill="#256AF4" Opacity="0.2">
                <Ellipse.RenderTransform>
                    <BlurEffect Radius="50"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            
            <Ellipse Width="234" Height="530"
                     Canvas.Right="-39" Canvas.Bottom="-88"
                     Fill="#2563EB" Opacity="0.1">
                <Ellipse.RenderTransform>
                    <BlurEffect Radius="60"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" 
                  Background="#101622" 
                  Opacity="0.6"
                  Padding="20,16">
                <Grid.BackgroundTransition>
                    <BrushTransition Duration="0:0:0.3"/>
                </Grid.BackgroundTransition>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="36" Height="36"
                        Background="Transparent"
                        CornerRadius="8"
                        Click="OnMenuClick">
                    <FontIcon Glyph="&#xE700;" FontSize="16" Foreground="#94A3B8"/>
                </Button>

                <StackPanel Grid.Column="1" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.Greeting, Mode=OneWay}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Opacity="0.9"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Spacing="6">
                        <Ellipse Width="6" Height="6" Fill="#6366F1"/>
                        <TextBlock Text="Vira AI"
                                   FontSize="11"
                                   Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="2"
                        Width="36" Height="36"
                        Background="Transparent"
                        CornerRadius="8"
                        Click="OnSettingsClick">
                    <FontIcon Glyph="&#xE713;" FontSize="16" Foreground="#94A3B8"/>
                </Button>
            </Grid>

            <!-- Chat Messages -->
            <ScrollViewer Grid.Row="1"
                          x:Name="ChatScrollViewer"
                          Padding="16,20,16,200"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ChatMessage">
                            <ContentControl Content="{x:Bind}"
                                          ContentTemplate="{StaticResource UserMessageTemplate}"
                                          HorizontalContentAlignment="Stretch"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input Area -->
            <Grid Grid.Row="2"
                  Background="#101622"
                  Padding="16,40,16,20">
                <Grid.BackgroundTransition>
                    <BrushTransition Duration="0:0:0.3"/>
                </Grid.BackgroundTransition>

                <StackPanel Spacing="12">
                    <!-- Quick Actions -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="🌤️ Cuaca" 
                                    Style="{StaticResource QuickActionButtonStyle}"
                                    Command="{x:Bind ViewModel.ExecuteQuickActionCommand}"
                                    CommandParameter="Bagaimana cuaca hari ini?"/>
                            <Button Content="📰 Berita" 
                                    Style="{StaticResource QuickActionButtonStyle}"
                                    Command="{x:Bind ViewModel.ExecuteQuickActionCommand}"
                                    CommandParameter="Tampilkan berita hari ini"/>
                            <Button Content="📅 Jadwal" 
                                    Style="{StaticResource QuickActionButtonStyle}"
                                    Command="{x:Bind ViewModel.ExecuteQuickActionCommand}"
                                    CommandParameter="Apa jadwal saya hari ini?"/>
                            <Button Content="🚗 Lalu Lintas" 
                                    Style="{StaticResource QuickActionButtonStyle}"
                                    Command="{x:Bind ViewModel.ExecuteQuickActionCommand}"
                                    CommandParameter="Cek kondisi lalu lintas"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Input Box -->
                    <Grid Background="#101622" 
                          Opacity="0.6"
                          CornerRadius="32"
                          Padding="6"
                          BorderBrush="White"
                          BorderThickness="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Width="36" Height="36"
                                Background="#FFFFFF0D"
                                CornerRadius="18"
                                Command="{x:Bind ViewModel.ClearChatCommand}">
                            <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="#94A3B8"/>
                        </Button>

                        <TextBox Grid.Column="1"
                                 Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Tanya Vira apa saja..."
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F8FAFC"
                                 FontSize="15"
                                 Padding="12,0"
                                 VerticalAlignment="Center"/>

                        <Button Grid.Column="2"
                                Width="40" Height="40"
                                Background="#FFFFFF0D"
                                CornerRadius="20"
                                Command="{x:Bind ViewModel.StartVoiceInputCommand}">
                            <FontIcon Glyph="&#xE720;" FontSize="18" Foreground="White"/>
                        </Button>

                        <Button Grid.Column="3"
                                Width="40" Height="40"
                                Background="#256AF4"
                                CornerRadius="20"
                                Command="{x:Bind ViewModel.SendMessageCommand}">
                            <FontIcon Glyph="&#xE724;" FontSize="16" Foreground="White"/>
                        </Button>
                    </Grid>

                    <!-- Bottom Handle -->
                    <Border Width="112" Height="4"
                            Background="White"
                            Opacity="0.15"
                            CornerRadius="2"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Typing Indicator -->
            <Border Grid.Row="1"
                    VerticalAlignment="Bottom"
                    Margin="16,0,16,220"
                    Visibility="{x:Bind ViewModel.IsTyping, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Background="#1E293B"
                        Opacity="0.9"
                        CornerRadius="16"
                        Padding="20,16"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="6" Height="6" Fill="#94A3B8">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="Dot1"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="6" Height="6" Fill="#94A3B8">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="Dot2"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="6" Height="6" Fill="#94A3B8">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="Dot3"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Page>
