<UserControl
    x:Class="VIRA.Shared.Views.LoadingIndicator"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Visibility="Collapsed">
        <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Spacing="12">
            <!-- Animated dots -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Spacing="8">
                <Ellipse x:Name="Dot1"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource PurpleGradientBrush}"/>
                <Ellipse x:Name="Dot2"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource PurpleGradientBrush}"/>
                <Ellipse x:Name="Dot3"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource PurpleGradientBrush}"/>
            </StackPanel>
            
            <!-- Loading text -->
            <TextBlock x:Name="LoadingText"
                       Text="Loading..."
                       FontSize="13"
                       Foreground="#94a3b8"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
