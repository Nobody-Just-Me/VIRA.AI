<Page
    x:Class="VIRA.Shared.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <Grid>
        <!-- Ambient background effects -->
        <Rectangle Fill="{StaticResource AmbientGlowBrush}" 
                   VerticalAlignment="Top" 
                   Height="300" 
                   Opacity="0.3"/>
        
        <ScrollViewer Padding="20">
            <StackPanel Spacing="24" MaxWidth="600">
                <!-- Header -->
                <Grid Margin="0,20,0,0">
                    <Button x:Name="BackButton"
                            Content="←"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="24"
                            Width="44"
                            Height="44"
                            Click="OnBackClick"/>
                    
                    <TextBlock Text="Settings" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
                
                <!-- Vira Profile Header -->
                <Border Background="#FFFFFF0D"
                        BorderBrush="#FFFFFF14"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Avatar -->
                        <Border Grid.Column="0"
                                Width="60"
                                Height="60"
                                CornerRadius="30"
                                Background="{StaticResource PurpleGradientBrush}">
                            <TextBlock Text="V"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- Stats -->
                        <StackPanel Grid.Column="1" 
                                    VerticalAlignment="Center"
                                    Margin="16,0,0,0">
                            <TextBlock Text="Vira AI Assistant"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="Active • Ready to assist"
                                       FontSize="13"
                                       Foreground="#94a3b8"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <!-- PRO Badge -->
                        <Border Grid.Column="2"
                                Background="{StaticResource PurpleGradientBrush}"
                                CornerRadius="8"
                                Padding="12,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="PRO"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- API Configuration Section -->
                <StackPanel Spacing="16">
                    <TextBlock Text="AI Provider Configuration"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    
                    <Border Background="#FFFFFF0D"
                            BorderBrush="#FFFFFF14"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="20">
                        <StackPanel Spacing="16">
                            <!-- Provider Selector -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Active Provider"
                                           FontSize="14"
                                           Foreground="#cbd5e1"/>
                                <ComboBox x:Name="ProviderSelector"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="OnProviderSelectionChanged">
                                    <ComboBoxItem Content="Groq" Tag="groq"/>
                                    <ComboBoxItem Content="OpenAI" Tag="openai"/>
                                    <ComboBoxItem Content="Gemini" Tag="gemini"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <!-- API Key Input -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="API Key"
                                           FontSize="14"
                                           Foreground="#cbd5e1"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <PasswordBox x:Name="ApiKeyInput"
                                                 Grid.Column="0"
                                                 PlaceholderText="Enter API key"
                                                 Margin="0,0,8,0"/>
                                    
                                    <Button x:Name="ShowHideKeyButton"
                                            Grid.Column="1"
                                            Content="👁️"
                                            Width="44"
                                            Height="44"
                                            Click="OnShowHideKeyClick"/>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Model Selector -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Model"
                                           FontSize="14"
                                           Foreground="#cbd5e1"/>
                                <ComboBox x:Name="ModelSelector"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <!-- Status Indicator -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Ellipse x:Name="StatusIndicator"
                                         Grid.Column="0"
                                         Width="12"
                                         Height="12"
                                         Fill="#94a3b8"
                                         Margin="0,0,8,0"/>
                                
                                <TextBlock x:Name="StatusText"
                                           Grid.Column="1"
                                           Text="Not configured"
                                           FontSize="13"
                                           Foreground="#94a3b8"/>
                            </Grid>
                            
                            <!-- Action Buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button x:Name="TestConnectionButton"
                                        Grid.Column="0"
                                        Content="Test Connection"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,0,8,0"
                                        Click="OnTestConnectionClick"/>
                                
                                <Button x:Name="SaveConfigButton"
                                        Grid.Column="1"
                                        Content="Save Configuration"
                                        Background="{StaticResource PurpleGradientBrush}"
                                        HorizontalAlignment="Stretch"
                                        Margin="8,0,0,0"
                                        Click="OnSaveConfigClick"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Preferences Section -->
                <StackPanel Spacing="16">
                    <TextBlock Text="Preferences"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    
                    <Border Background="#FFFFFF0D"
                            BorderBrush="#FFFFFF14"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="20">
                        <StackPanel Spacing="16">
                            <!-- Theme Selector -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                           Text="Theme"
                                           FontSize="14"
                                           Foreground="#cbd5e1"
                                           VerticalAlignment="Center"/>
                                
                                <ComboBox Grid.Column="1"
                                          x:Name="ThemeSelector"
                                          MinWidth="120">
                                    <ComboBoxItem Content="Dark" IsSelected="True"/>
                                    <ComboBoxItem Content="Light"/>
                                    <ComboBoxItem Content="System"/>
                                </ComboBox>
                            </Grid>
                            
                            <!-- Toggle Switches -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                           Text="Voice Output"
                                           FontSize="14"
                                           Foreground="#cbd5e1"
                                           VerticalAlignment="Center"/>
                                
                                <ToggleSwitch Grid.Column="1"
                                              x:Name="VoiceOutputToggle"
                                              IsOn="True"/>
                            </Grid>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                           Text="Web Browsing"
                                           FontSize="14"
                                           Foreground="#cbd5e1"
                                           VerticalAlignment="Center"/>
                                
                                <ToggleSwitch Grid.Column="1"
                                              x:Name="WebBrowsingToggle"
                                              IsOn="True"/>
                            </Grid>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                           Text="Haptics"
                                           FontSize="14"
                                           Foreground="#cbd5e1"
                                           VerticalAlignment="Center"/>
                                
                                <ToggleSwitch Grid.Column="1"
                                              x:Name="HapticsToggle"
                                              IsOn="True"/>
                            </Grid>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                           Text="Notifications"
                                           FontSize="14"
                                           Foreground="#cbd5e1"
                                           VerticalAlignment="Center"/>
                                
                                <ToggleSwitch Grid.Column="1"
                                              x:Name="NotificationsToggle"
                                              IsOn="True"/>
                            </Grid>
                            
                            <!-- Language Selector -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                           Text="Language"
                                           FontSize="14"
                                           Foreground="#cbd5e1"
                                           VerticalAlignment="Center"/>
                                
                                <ComboBox Grid.Column="1"
                                          x:Name="LanguageSelector"
                                          MinWidth="120">
                                    <ComboBoxItem Content="English" IsSelected="True"/>
                                    <ComboBoxItem Content="Spanish"/>
                                    <ComboBoxItem Content="French"/>
                                    <ComboBoxItem Content="German"/>
                                </ComboBox>
                            </Grid>
                            
                            <!-- Response Style -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                           Text="Response Style"
                                           FontSize="14"
                                           Foreground="#cbd5e1"
                                           VerticalAlignment="Center"/>
                                
                                <ComboBox Grid.Column="1"
                                          x:Name="ResponseStyleSelector"
                                          MinWidth="120">
                                    <ComboBoxItem Content="Balanced" IsSelected="True"/>
                                    <ComboBoxItem Content="Concise"/>
                                    <ComboBoxItem Content="Detailed"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- AI Behaviour Section -->
                <StackPanel Spacing="16">
                    <TextBlock Text="AI Behaviour"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    
                    <Border Background="#FFFFFF0D"
                            BorderBrush="#FFFFFF14"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="20">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Memory Mode"
                                               FontSize="14"
                                               Foreground="#cbd5e1"/>
                                    <TextBlock Text="Remember conversation context"
                                               FontSize="12"
                                               Foreground="#64748b"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <ToggleSwitch Grid.Column="1"
                                              x:Name="MemoryModeToggle"
                                              IsOn="True"/>
                            </Grid>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Privacy Mode"
                                               FontSize="14"
                                               Foreground="#cbd5e1"/>
                                    <TextBlock Text="Don't save conversations"
                                               FontSize="12"
                                               Foreground="#64748b"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <ToggleSwitch Grid.Column="1"
                                              x:Name="PrivacyModeToggle"
                                              IsOn="False"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Bottom spacing -->
                <Border Height="40"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
