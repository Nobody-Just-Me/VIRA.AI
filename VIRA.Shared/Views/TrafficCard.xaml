<UserControl x:Class="VIRA.Shared.Views.TrafficCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:VIRA.Shared.Models"
             xmlns:converters="using:VIRA.Shared.Converters">
    
    <UserControl.Resources>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>
    </UserControl.Resources>
    
    <Border Background="{StaticResource SemiTransparentWhite5Brush}" 
            BorderBrush="{StaticResource SemiTransparentWhite14Brush}" 
            BorderThickness="1"
            CornerRadius="{StaticResource MediumRadius}"
            Padding="{StaticResource SpacingMedium}">
        
        <StackPanel Spacing="{StaticResource SpacingSmall}">
            <!-- Header -->
            <TextBlock Text="🚗 Traffic Conditions" 
                       FontSize="{StaticResource FontSizeLarge}" 
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontWeight="SemiBold"/>
            
            <!-- Traffic Routes List -->
            <ItemsRepeater ItemsSource="{x:Bind TrafficRoutes, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:TrafficRoute">
                        <Border Background="{StaticResource SemiTransparentWhite8Brush}" 
                                CornerRadius="{StaticResource SmallRadius}" 
                                Padding="12"
                                Margin="0,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Color-coded Status Indicator -->
                                <Border Grid.Column="0"
                                        Width="8"
                                        Height="8"
                                        CornerRadius="4"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="{x:Bind Color, Converter={StaticResource StringToColorConverter}}"/>
                                    </Border.Background>
                                </Border>
                                
                                <!-- Route Details -->
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <!-- Route Name -->
                                    <TextBlock Text="{x:Bind Route}" 
                                               FontSize="{StaticResource FontSizeNormal}" 
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="Medium"/>
                                    
                                    <!-- Status -->
                                    <TextBlock Text="{x:Bind Status}" 
                                               FontSize="{StaticResource FontSizeSmall}" 
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                </StackPanel>
                                
                                <!-- ETA -->
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind ETA}" 
                                           FontSize="{StaticResource FontSizeNormal}" 
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </Border>
</UserControl>
