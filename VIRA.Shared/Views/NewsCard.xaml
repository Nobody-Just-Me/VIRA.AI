<UserControl x:Class="VIRA.Shared.Views.NewsCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:VIRA.Shared.Models">
    
    <Border Background="{StaticResource SemiTransparentWhite5Brush}" 
            BorderBrush="{StaticResource SemiTransparentWhite14Brush}" 
            BorderThickness="1"
            CornerRadius="{StaticResource MediumRadius}"
            Padding="{StaticResource SpacingMedium}">
        
        <StackPanel Spacing="{StaticResource SpacingSmall}">
            <!-- Header -->
            <TextBlock Text="📰 Latest News" 
                       FontSize="{StaticResource FontSizeLarge}" 
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontWeight="SemiBold"/>
            
            <!-- News Items List -->
            <ItemsRepeater ItemsSource="{x:Bind NewsItems, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:NewsItem">
                        <Border Background="{StaticResource SemiTransparentWhite8Brush}" 
                                CornerRadius="{StaticResource SmallRadius}" 
                                Padding="12"
                                Margin="0,4,0,0">
                            <StackPanel Spacing="6">
                                <!-- Category Badge -->
                                <Border Background="{StaticResource InfoBlueBrush}"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{x:Bind Category}" 
                                               FontSize="{StaticResource FontSizeXSmall}" 
                                               Foreground="{StaticResource TextWhiteBrush}"
                                               FontWeight="SemiBold"/>
                                </Border>
                                
                                <!-- News Title -->
                                <TextBlock Text="{x:Bind Title}" 
                                           FontSize="{StaticResource FontSizeNormal}" 
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </Border>
</UserControl>
