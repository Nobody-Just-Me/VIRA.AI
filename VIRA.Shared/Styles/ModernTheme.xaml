<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================================
         COLORS
         All color values from reference design
         ======================================== -->
    
    <!-- Base Colors -->
    <Color x:Key="BackgroundColor">#101622</Color>
    <Color x:Key="PurpleGradientStartColor">#8b5cf6</Color>
    <Color x:Key="PurpleGradientEndColor">#7c3aed</Color>
    <Color x:Key="IndigoAccentColor">#6366f1</Color>
    
    <!-- Semi-transparent Whites -->
    <Color x:Key="SemiTransparentWhite5">#0DFFFFFF</Color>
    <Color x:Key="SemiTransparentWhite8">#14FFFFFF</Color>
    <Color x:Key="SemiTransparentWhite14">#24FFFFFF</Color>
    
    <!-- Status Colors -->
    <Color x:Key="SuccessGreenColor">#22c55e</Color>
    <Color x:Key="WarningYellowColor">#eab308</Color>
    <Color x:Key="ErrorRedColor">#ef4444</Color>
    <Color x:Key="InfoBlueColor">#2094f3</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="TextSecondaryColor">#cbd5e1</Color>
    <Color x:Key="TextTertiaryColor">#94a3b8</Color>
    <Color x:Key="TextQuaternaryColor">#64748b</Color>
    <Color x:Key="TextWhiteColor">#FFFFFF</Color>
    
    <!-- Ambient Glow Colors -->
    <Color x:Key="AmbientGlowPurpleColor">#8b5cf6</Color>
    <Color x:Key="AmbientGlowIndigoColor">#6366f1</Color>

    <!-- ========================================
         SOLID COLOR BRUSHES
         ======================================== -->
    
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PurpleGradientStartBrush" Color="{StaticResource PurpleGradientStartColor}"/>
    <SolidColorBrush x:Key="PurpleGradientEndBrush" Color="{StaticResource PurpleGradientEndColor}"/>
    <SolidColorBrush x:Key="IndigoAccentBrush" Color="{StaticResource IndigoAccentColor}"/>
    
    <SolidColorBrush x:Key="SemiTransparentWhite5Brush" Color="{StaticResource SemiTransparentWhite5}"/>
    <SolidColorBrush x:Key="SemiTransparentWhite8Brush" Color="{StaticResource SemiTransparentWhite8}"/>
    <SolidColorBrush x:Key="SemiTransparentWhite14Brush" Color="{StaticResource SemiTransparentWhite14}"/>
    
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="WarningYellowBrush" Color="{StaticResource WarningYellowColor}"/>
    <SolidColorBrush x:Key="ErrorRedBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="InfoBlueBrush" Color="{StaticResource InfoBlueColor}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextQuaternaryBrush" Color="{StaticResource TextQuaternaryColor}"/>
    <SolidColorBrush x:Key="TextWhiteBrush" Color="{StaticResource TextWhiteColor}"/>

    <!-- ========================================
         GRADIENT BRUSHES
         ======================================== -->
    
    <!-- Purple Gradient for User Messages and Buttons -->
    <LinearGradientBrush x:Key="PurpleGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PurpleGradientStartColor}" Offset="0"/>
        <GradientStop Color="{StaticResource PurpleGradientEndColor}" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Ambient Glow Gradient for Background Effects -->
    <LinearGradientBrush x:Key="AmbientGlowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AmbientGlowPurpleColor}" Offset="0"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Ambient Glow Gradient (Indigo variant) -->
    <LinearGradientBrush x:Key="AmbientGlowIndigoBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AmbientGlowIndigoColor}" Offset="0"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Input Area Gradient (Dark to Transparent) -->
    <LinearGradientBrush x:Key="InputAreaGradientBrush" StartPoint="0,1" EndPoint="0,0">
        <GradientStop Color="{StaticResource BackgroundColor}" Offset="0"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- AI Message Background (Semi-transparent with blur effect) -->
    <SolidColorBrush x:Key="AIMessageBrush" Color="{StaticResource SemiTransparentWhite5}"/>

    <!-- ========================================
         SHADOWS - Removed for Android compatibility
         Shadow properties are not supported on Android
         ======================================== -->

    <!-- ========================================
         BORDER RADIUS (CORNER RADIUS)
         ======================================== -->
    
    <CornerRadius x:Key="SmallRadius">8</CornerRadius>
    <CornerRadius x:Key="MediumRadius">16</CornerRadius>
    <CornerRadius x:Key="LargeRadius">24</CornerRadius>
    <CornerRadius x:Key="XLargeRadius">32</CornerRadius>
    
    <!-- Asymmetric corner radius for message bubbles -->
    <CornerRadius x:Key="MessageBubbleRadius">16,16,16,2</CornerRadius>

    <!-- ========================================
         SPACING VALUES
         ======================================== -->
    
    <x:Double x:Key="SpacingXSmall">4</x:Double>
    <x:Double x:Key="SpacingSmall">8</x:Double>
    <x:Double x:Key="SpacingMedium">16</x:Double>
    <x:Double x:Key="SpacingLarge">24</x:Double>
    <x:Double x:Key="SpacingXLarge">32</x:Double>
    <x:Double x:Key="SpacingXXLarge">48</x:Double>

    <!-- ========================================
         FONT SIZES
         ======================================== -->
    
    <x:Double x:Key="FontSizeXSmall">10</x:Double>
    <x:Double x:Key="FontSizeSmall">11</x:Double>
    <x:Double x:Key="FontSizeMedium">13</x:Double>
    <x:Double x:Key="FontSizeNormal">14</x:Double>
    <x:Double x:Key="FontSizeLarge">15</x:Double>
    <x:Double x:Key="FontSizeXLarge">18</x:Double>
    <x:Double x:Key="FontSizeXXLarge">24</x:Double>
    <x:Double x:Key="FontSizeHuge">48</x:Double>

    <!-- ========================================
         ANIMATION DURATIONS (in milliseconds)
         ======================================== -->
    
    <x:Int32 x:Key="MessageEntranceDuration">280</x:Int32>
    <x:Int32 x:Key="SidebarSlideDuration">300</x:Int32>
    <x:Int32 x:Key="ButtonTapDuration">200</x:Int32>
    <x:Int32 x:Key="WaveformUpdateInterval">50</x:Int32>
    <x:Int32 x:Key="NotificationDismissDelay">3000</x:Int32>
    <x:Int32 x:Key="VoiceButtonPulseDuration">500</x:Int32>

</ResourceDictionary>
