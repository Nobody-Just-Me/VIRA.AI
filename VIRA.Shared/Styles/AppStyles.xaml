<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:VIRA.Shared.Converters">

    <!-- Color Palette -->
    <Color x:Key="SlateBackground">#101622</Color>
    <Color x:Key="SlateDark">#0F172A</Color>
    <Color x:Key="SlateCard">#1E293B</Color>
    <Color x:Key="SlateBorder">#334155</Color>
    <Color x:Key="SlateText">#F8FAFC</Color>
    <Color x:Key="SlateTextSecondary">#94A3B8</Color>
    <Color x:Key="PrimaryBlue">#256AF4</Color>
    <Color x:Key="PrimaryPurple">#6366F1</Color>

    <SolidColorBrush x:Key="SlateBackgroundBrush" Color="{StaticResource SlateBackground}"/>
    <SolidColorBrush x:Key="SlateDarkBrush" Color="{StaticResource SlateDark}"/>
    <SolidColorBrush x:Key="SlateCardBrush" Color="{StaticResource SlateCard}"/>
    <SolidColorBrush x:Key="SlateBorderBrush" Color="{StaticResource SlateBorder}"/>
    <SolidColorBrush x:Key="SlateTextBrush" Color="{StaticResource SlateText}"/>
    <SolidColorBrush x:Key="SlateTextSecondaryBrush" Color="{StaticResource SlateTextSecondary}"/>
    <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}"/>
    <SolidColorBrush x:Key="PrimaryPurpleBrush" Color="{StaticResource PrimaryPurple}"/>

    <!-- Quick Action Button Style -->
    <Style x:Key="QuickActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#FFFFFF0D"/>
        <Setter Property="Foreground" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="#FFFFFF1A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- Glass Card Style -->
    <Style x:Key="GlassCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="BorderBrush" Value="#FFFFFF14"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- Primary Button Style -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Secondary Button Style -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SlateCardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource SlateTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SlateBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Converters -->
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

</ResourceDictionary>
